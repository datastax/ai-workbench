{
	"name": "ai-workbench-runtime-typescript",
	"version": "0.0.0",
	"description": "AI Workbench — TypeScript runtime (default green box). Bundled with the UI.",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=22.0.0"
	},
	"main": "dist/root.js",
	"scripts": {
		"dev": "tsx watch src/root.ts",
		"start": "node dist/root.js",
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"conformance:mock": "tsx ../../conformance/mock-astra/server.ts",
		"conformance:regenerate": "tsx scripts/conformance-regenerate.ts"
	},
	"dependencies": {
		"@datastax/astra-db-ts": "^2.2.1",
		"@hono/node-server": "^1.14.0",
		"@hono/zod-openapi": "^1.3.0",
		"@scalar/hono-api-reference": "^0.10.9",
		"hono": "^4.7.0",
		"pino": "^9.6.0",
		"ulid": "^2.3.0",
		"yaml": "^2.7.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"pino-pretty": "^13.0.0",
		"tsx": "^4.19.4",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
