{
	"name": "ai-workbench-runtime-typescript",
	"version": "0.0.0",
	"description": "AI Workbench — TypeScript runtime (default green box). Bundled with the UI.",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=22.0.0"
	},
	"main": "dist/root.js",
	"scripts": {
		"dev": "tsx watch src/root.ts",
		"start": "node dist/root.js",
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"conformance:mock": "tsx ../../conformance/mock-astra/server.ts",
		"conformance:regenerate": "tsx scripts/conformance-regenerate.ts",
		"smoke:astra": "tsx scripts/smoke-astra.ts"
	},
	"dependencies": {
		"@ai-sdk/openai": "^3.0.53",
		"@datastax/astra-db-ts": "^2.2.1",
		"@hono/node-server": "^2.0.0",
		"@hono/zod-openapi": "^1.3.0",
		"@scalar/hono-api-reference": "^0.10.10",
		"ai": "^6.0.168",
		"hono": "^4.12.15",
		"jose": "^6.2.2",
		"pino": "^10.3.1",
		"ulid": "^3.0.2",
		"yaml": "^2.7.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"pino-pretty": "^13.0.0",
		"tsx": "^4.19.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"overrides": {
		"uuid": "^14.0.0"
	}
}
