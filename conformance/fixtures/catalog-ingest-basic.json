				],
				"status": 200
			},
			"step": 5
		},
		{
			"request": {
				"body": {
					"name": "unbound"
				},
				"method": "POST",
				"path": "/api/v1/workspaces/{{UUID_1}}/catalogs"
			},
			"response": {
				"body": {
					"createdAt": "{{TS}}",
					"description": null,
					"name": "unbound",
					"uid": "{{UUID_5}}",
					"updatedAt": "{{TS}}",
					"vectorStore": null,
					"workspace": "{{UUID_1}}"
				},
				"status": 201
			},
			"step": 6
		},
		{
			"request": {
				"body": {
					"text": "no home for this"
				},
				"method": "POST",
				"path": "/api/v1/workspaces/{{UUID_1}}/catalogs/{{UUID_5}}/ingest"
			},
			"response": {
				"body": {
					"error": {
						"code": "catalog_not_bound_to_vector_store",
						"message": "catalog '{{UUID_5}}' has no vectorStore binding; bind one with PUT /catalogs/{id} before ingesting",
