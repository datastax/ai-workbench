						"md5Hash": null,
						"metadata": {},
						"sourceDocId": null,
						"sourceFilename": "fruit.md",
						"status": "ready",
						"updatedAt": "{{TS}}",
						"workspace": "{{UUID_1}}"
					}
				},
				"status": 201
			},
			"step": 4
		},
		{
			"request": {
				"body": null,
				"method": "GET",
				"path": "/api/v1/workspaces/{{UUID_1}}/catalogs/{{UUID_3}}/documents"
			},
			"response": {
				"body": [
					{
						"catalogUid": "{{UUID_3}}",
						"chunkTotal": 3,
