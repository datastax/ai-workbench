					"vectorStore": "{{UUID_2}}",
					"workspace": "{{UUID_1}}"
				},
				"status": 201
			},
			"step": 3
		},
		{
			"request": {
				"body": {
					"chunker": {
						"maxChars": 20,
						"minChars": 5,
						"overlapChars": 3
					},
					"sourceFilename": "fruit.md",
					"text": "Apples are red. Bananas are yellow."
				},
				"method": "POST",
				"path": "/api/v1/workspaces/{{UUID_1}}/catalogs/{{UUID_3}}/ingest"
			},
			"response": {
				"body": {
					"chunks": 3,
