{
	"slug": "catalog-ingest-basic",
	"description": "POST /catalogs/{c}/ingest chunks + embeds + upserts synchronously. Document row is created with status=ready and chunkTotal reflects chunker output. A second ingest against an unbound catalog returns 409 catalog_not_bound_to_vector_store.",
	"captures": [
		{
			"request": {
				"body": {
					"kind": "mock",
					"name": "w"
				},
				"method": "POST",
				"path": "/api/v1/workspaces"
			},
			"response": {
				"body": {
