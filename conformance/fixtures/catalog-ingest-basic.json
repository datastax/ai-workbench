					"name": "w",
					"uid": "{{UUID_1}}",
					"updatedAt": "{{TS}}"
				},
				"status": 201
			},
			"step": 1
		},
		{
			"request": {
				"body": {
					"embedding": {
						"dimension": 4,
						"endpoint": null,
						"model": "mock-embedder",
						"provider": "mock",
						"secretRef": null
					},
					"name": "vs",
					"vectorDimension": 4
				},
				"method": "POST",
				"path": "/api/v1/workspaces/{{UUID_1}}/vector-stores"
			},
			"response": {
				"body": {
					"createdAt": "{{TS}}",
					"embedding": {
						"dimension": 4,
						"endpoint": null,
						"model": "mock-embedder",
						"provider": "mock",
						"secretRef": null
					},
					"lexical": {
						"analyzer": null,
						"enabled": false,
						"options": {}
					},
					"name": "vs",
					"reranking": {
						"enabled": false,
						"endpoint": null,
						"model": null,
						"provider": null,
						"secretRef": null
					},
					"uid": "{{UUID_2}}",
					"updatedAt": "{{TS}}",
					"vectorDimension": 4,
					"vectorSimilarity": "cosine",
					"workspace": "{{UUID_1}}"
				},
				"status": 201
			},
			"step": 2
		},
		{
			"request": {
				"body": {
					"name": "kb",
					"vectorStore": "{{UUID_2}}"
				},
				"method": "POST",
				"path": "/api/v1/workspaces/{{UUID_1}}/catalogs"
			},
			"response": {
