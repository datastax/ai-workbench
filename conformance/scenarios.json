			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.uid/vector-stores",
				"body": {
					"name": "vs",
					"vectorDimension": 4,
					"embedding": {
						"provider": "mock",
						"model": "mock-embedder",
						"endpoint": null,
						"dimension": 4,
						"secretRef": null
					}
				}
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.uid/catalogs",
				"body": { "name": "kb", "vectorStore": "$2.uid" }
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.uid/catalogs/$3.uid/ingest",
				"body": {
					"text": "Apples are red. Bananas are yellow.",
					"sourceFilename": "fruit.md",
					"chunker": { "maxChars": 20, "minChars": 5, "overlapChars": 3 }
