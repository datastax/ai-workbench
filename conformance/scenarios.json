				"path": "/api/v1/workspaces",
				"body": { "name": "prod", "kind": "astra" }
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces"
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.uid"
			},
			{
				"method": "PUT",
				"path": "/api/v1/workspaces/$1.uid",
				"body": { "name": "production" }
			},
			{
				"method": "DELETE",
				"path": "/api/v1/workspaces/$1.uid"
			}
		]
	},
	{
