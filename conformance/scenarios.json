				"path": "/api/v1/workspaces/$1.uid/catalogs",
				"body": { "name": "unbound" }
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.uid/catalogs/$6.uid/ingest",
				"body": { "text": "no home for this" }
			}
		]
	},
