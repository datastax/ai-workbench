	{
		"slug": "vector-store-definition",
		"description": "Descriptor row in wb_vector_store_by_workspace plus the underlying collection provisioning (mock kind to keep the fixture runtime-agnostic).",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "w", "kind": "mock" }
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.uid/vector-stores",
				"body": {
					"name": "vs",
					"vectorDimension": 4,
					"embedding": {
						"provider": "mock",
						"model": "mock-embedder",
						"endpoint": null,
						"dimension": 4,
						"secretRef": null
					}
				}
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.uid/vector-stores/$2.uid"
			}
		]
	},
	{
		"slug": "vector-store-upsert-and-search",
		"description": "End-to-end data plane: create a vector store, upsert 3 records, search with topK=2 + a payload filter, delete one record.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "w", "kind": "mock" }
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.uid/vector-stores",
				"body": {
					"name": "vs",
					"vectorDimension": 4,
					"vectorSimilarity": "cosine",
					"embedding": {
						"provider": "mock",
						"model": "mock-embedder",
						"endpoint": null,
						"dimension": 4,
						"secretRef": null
					}
				}
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.uid/vector-stores/$2.uid/records",
				"body": {
					"records": [
						{ "id": "a", "vector": [1, 0, 0, 0], "payload": { "tag": "keep" } },
						{ "id": "b", "vector": [0, 1, 0, 0], "payload": { "tag": "drop" } },
						{
							"id": "c",
							"vector": [0.9, 0.1, 0, 0],
							"payload": { "tag": "keep" }
						}
					]
				}
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.uid/vector-stores/$2.uid/search",
				"body": {
					"vector": [1, 0, 0, 0],
					"topK": 2,
					"filter": { "tag": "keep" }
				}
			},
			{
				"method": "DELETE",
				"path": "/api/v1/workspaces/$1.uid/vector-stores/$2.uid/records/a"
			},
			{
				"method": "DELETE",
				"path": "/api/v1/workspaces/$1.uid/vector-stores/$2.uid/records/a"
			}
		]
	},
	{
		"slug": "document-crud-basic",
		"description": "Document metadata CRUD under a catalog: create → list → get → update → delete, including a cross-catalog scoping 404.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "w", "kind": "astra" }
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.uid/catalogs",
				"body": { "name": "support" }
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.uid/catalogs",
				"body": { "name": "other" }
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.uid/catalogs/$2.uid/documents",
				"body": {
					"sourceFilename": "readme.md",
					"fileType": "text/markdown",
					"fileSize": 1024,
					"metadata": { "source": "upload" }
				}
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.uid/catalogs/$2.uid/documents"
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.uid/catalogs/$2.uid/documents/$4.documentUid"
			},
			{
				"method": "PUT",
				"path": "/api/v1/workspaces/$1.uid/catalogs/$2.uid/documents/$4.documentUid",
				"body": { "status": "ready", "chunkTotal": 7 }
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.uid/catalogs/$3.uid/documents/$4.documentUid"
			},
			{
				"method": "DELETE",
				"path": "/api/v1/workspaces/$1.uid/catalogs/$2.uid/documents/$4.documentUid"
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.uid/catalogs/$2.uid/documents/$4.documentUid"
			}
		]
	},
	{
		"slug": "workspace-kind-is-immutable",
		"description": "`PUT /workspaces/{uid}` rejects a `kind` field with 400 validation_error. A workspace's backend is immutable after creation; the canonical error envelope must say so.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "w", "kind": "astra" }
			},
			{
				"method": "PUT",
				"path": "/api/v1/workspaces/$1.uid",
				"body": { "kind": "mock" }
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.uid"
			}
		]
	},
	{
		"slug": "workspace-credentials-must-be-secret-ref",
		"description": "`credentialsRef` values must match `<provider>:<path>` (e.g. `env:ASTRA_TOKEN`). A raw token value is rejected with 400 validation_error — it never reaches the SecretResolver.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": {
					"name": "w",
					"kind": "astra",
					"credentialsRef": { "token": "raw-token-here" }
				}
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces"
			}
		]
	},
	{
		"slug": "workspace-test-connection-mock",
		"description": "`POST /workspaces/{uid}/test-connection` on a mock workspace always reports ok: true. Pins the response shape (ok, kind, details) so every runtime implements the probe identically. Kinds that resolve credentials via SecretResolver are environment-dependent and aren't in the conformance corpus.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "w", "kind": "mock" }
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.uid/test-connection"
			}
		]
	},
	{
		"slug": "workspace-api-key-lifecycle",
		"description": "Full API-key CRUD: issue (plaintext shown once, hash never exposed) → list → revoke (soft-revoke, row stays) → list (revokedAt populated). Pins the `plaintext + key` envelope on POST and the stripped-hash shape on GET.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "w", "kind": "mock" }
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.uid/api-keys",
				"body": { "label": "ci" }
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.uid/api-keys"
			},
			{
				"method": "DELETE",
				"path": "/api/v1/workspaces/$1.uid/api-keys/$2.key.keyId"
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.uid/api-keys"
			}
		]
	}
]
