[
	{
		"slug": "workspace-crud-basic",
		"description": "Minimum viable workspace lifecycle.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "prod", "kind": "astra" }
			},
			{ "method": "GET", "path": "/api/v1/workspaces" },
			{ "method": "GET", "path": "/api/v1/workspaces/$1.workspaceId" },
			{
				"method": "PATCH",
				"path": "/api/v1/workspaces/$1.workspaceId",
				"body": { "name": "production" }
			},
			{ "method": "DELETE", "path": "/api/v1/workspaces/$1.workspaceId" }
		]
	},
	{
		"slug": "workspace-kind-is-immutable",
		"description": "`PATCH /workspaces/{workspaceId}` rejects a `kind` field with 400 validation_error. A workspace's backend is immutable after creation; the canonical error envelope must say so.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "w", "kind": "astra" }
			},
			{
				"method": "PATCH",
				"path": "/api/v1/workspaces/$1.workspaceId",
				"body": { "kind": "mock" }
			},
			{ "method": "GET", "path": "/api/v1/workspaces/$1.workspaceId" }
		]
	},
	{
		"slug": "workspace-credentials-must-be-secret-ref",
		"description": "Raw credential values are rejected with 400 validation_error before they can reach the SecretResolver.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": {
					"name": "w",
					"kind": "astra",
					"credentials": { "token": "AstraCS:plaintext" }
				}
			}
		]
	},
	{
		"slug": "workspace-test-connection-mock",
		"description": "POST /workspaces/{workspaceId}/test-connection on a mock workspace always reports ok: true with the portable response shape.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "w", "kind": "mock" }
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.workspaceId/test-connection"
			}
		]
	},
	{
		"slug": "workspace-api-key-lifecycle",
		"description": "Full workspace API-key lifecycle: issue, list, revoke, list. The plaintext is returned exactly once; list responses expose metadata without the stored hash.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "w", "kind": "mock" }
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.workspaceId/api-keys",
				"body": { "label": "ci" }
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/api-keys"
			},
			{
				"method": "DELETE",
				"path": "/api/v1/workspaces/$1.workspaceId/api-keys/$2.keyId"
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/api-keys"
			}
		]
	},
	{
		"slug": "knowledge-base-crud-basic",
		"description": "Knowledge-base CRUD lifecycle. Workspace POST auto-seeds the default chunking + embedding + LLM services; the KB binds to one of each by id, then we round-trip through GET / list / PATCH / DELETE. Pinned response shape: KB record carries embeddingServiceId / chunkingServiceId / vectorCollection / status.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "w", "kind": "mock" }
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/embedding-services"
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/chunking-services"
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases",
				"body": {
					"name": "research",
					"description": "internal docs",
					"embeddingServiceId": "$2.items.0.embeddingServiceId",
					"chunkingServiceId": "$3.items.0.chunkingServiceId"
				}
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases/$4.knowledgeBaseId"
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases"
			},
			{
				"method": "PATCH",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases/$4.knowledgeBaseId",
				"body": { "description": "updated description" }
			},
			{
				"method": "DELETE",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases/$4.knowledgeBaseId"
			}
		]
	},
	{
		"slug": "kb-document-crud-basic",
		"description": "Document CRUD on a knowledge base WITHOUT triggering ingest. Pins the wire shape of the document record (status, sourceFilename, metadata, chunkCount) and the list/get/patch/delete envelope. Ingest with chunking is excluded from conformance because chunk counts depend on the chunker's tokenization, which is allowed to vary across runtimes.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "w", "kind": "mock" }
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/embedding-services"
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/chunking-services"
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases",
				"body": {
					"name": "kb",
					"embeddingServiceId": "$2.items.0.embeddingServiceId",
					"chunkingServiceId": "$3.items.0.chunkingServiceId"
				}
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases/$4.knowledgeBaseId/documents",
				"body": {
					"sourceFilename": "alpha.txt",
					"metadata": { "tag": "intro" }
				}
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases/$4.knowledgeBaseId/documents"
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases/$4.knowledgeBaseId/documents/$5.documentId"
			},
			{
				"method": "PATCH",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases/$4.knowledgeBaseId/documents/$5.documentId",
				"body": { "metadata": { "tag": "intro", "reviewed": "yes" } }
			},
			{
				"method": "DELETE",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases/$4.knowledgeBaseId/documents/$5.documentId"
			}
		]
	},
	{
		"slug": "kb-search-empty",
		"description": "Search on an empty knowledge base returns an empty results array with the canonical envelope (results, query, knowledgeBaseId). This pins the response shape every runtime must emit when no documents have been ingested. Search-with-results scenarios are excluded because they depend on embedder/chunker behavior that's allowed to vary; conformance only pins the wire shape on the empty-result path.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "w", "kind": "mock" }
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/embedding-services"
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/chunking-services"
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases",
				"body": {
					"name": "kb",
					"embeddingServiceId": "$2.items.0.embeddingServiceId",
					"chunkingServiceId": "$3.items.0.chunkingServiceId"
				}
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases/$4.knowledgeBaseId/search",
				"body": { "query": "anything", "topK": 3 }
			}
		]
	},
	{
		"slug": "agent-crud-basic",
		"description": "Agent + conversation CRUD lifecycle WITHOUT triggering chat sends. Workspace POST auto-seeds the default LLM service; we bind an agent to it, open a conversation, and tear down. The GET /agents list step is intentionally omitted because workspace POST also auto-seeds two default agents (Bobby + Heidi) whose createdAt timestamps frequently collide at millisecond resolution and sort nondeterministically — the per-agent GET below already pins the wire shape every runtime must produce. Sending messages is excluded from conformance because chat completion depends on the upstream LLM API that's not part of the runtime contract.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "w", "kind": "mock" }
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/llm-services"
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.workspaceId/agents",
				"body": {
					"name": "researcher",
					"description": "internal-docs Q&A",
					"llmServiceId": "$2.items.0.llmServiceId"
				}
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/agents/$3.agentId"
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.workspaceId/agents/$3.agentId/conversations",
				"body": { "title": "thread one" }
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/agents/$3.agentId/conversations"
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/agents/$3.agentId/conversations/$5.conversationId/messages"
			},
			{
				"method": "DELETE",
				"path": "/api/v1/workspaces/$1.workspaceId/agents/$3.agentId/conversations/$5.conversationId"
			},
			{
				"method": "DELETE",
				"path": "/api/v1/workspaces/$1.workspaceId/agents/$3.agentId"
			}
		]
	}
]
