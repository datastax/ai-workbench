# AI Workbench — sample environment file.
#
# Copy to `.env` at the repo root and fill in the secrets you need.
# The runtime auto-loads this on startup (Node 21.7+ via
# `process.loadEnvFile`). `.env` is gitignored; `.env.example` is the
# committed template.
#
# Precedence: values already set in the shell / container environment
# win over entries here. Matches standard dotenv semantics.
#
# Override the file location with WORKBENCH_ENV_FILE=/path/to/file,
# which is handy for production container boots where the token lives
# on a mounted secret.

# --- Astra control plane (only needed when workbench.yaml picks the
# `astra` driver; see docs/configuration.md#astra) ---
#
# Tip: if you have the DataStax `astra` CLI installed and a profile
# configured (`astra setup`), you can leave the two variables below
# unset — the runtime will pick them up from the CLI at startup. See
# docs/astra-cli.md. Set ASTRA_PROFILE / ASTRA_DB to skip the prompts,
# or WORKBENCH_DISABLE_ASTRA_CLI=1 to opt out entirely.
#
# ASTRA_DB_API_ENDPOINT=https://<db-id>-<region>.apps.astra.datastax.com
# ASTRA_DB_APPLICATION_TOKEN=AstraCS:...
#
# Used by `npm run smoke:astra` (a dev-only sanity check that
# round-trips a real Astra DB). Production runtime reads keyspaces
# per-workspace from `workbench.yaml`, not this variable.
# ASTRA_DB_KEYSPACE=default_keyspace

# --- Workspace credential refs ---
# A workspace of `kind: astra` typically declares
#   credentialsRef: { token: "env:ASTRA_DB_APPLICATION_TOKEN" }
# The runtime resolves that ref from this env at use time — so the
# same ASTRA_DB_APPLICATION_TOKEN above is what the test-connection
# probe reads.

# --- Chat with Bobbie (HuggingFace inference) ---
# Required when the `chat` block is uncommented in workbench.yaml.
# Generate a token at https://huggingface.co/settings/tokens with
# read scope. POST /api/v1/workspaces/{w}/chats/{c}/messages returns
# 503 chat_disabled when the runtime can't resolve this.
#
# HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Runtime overrides (optional; `workbench.yaml` is canonical) ---
# When set, these env vars override the matching keys in
# `runtime:` in `workbench.yaml`. Documented in
# docs/configuration.md. Useful for container deployments where the
# YAML is mounted read-only but log verbosity / asset path need to
# be tweaked per-replica.
#
# LOG_LEVEL=info
# UI_DIR=/app/public
