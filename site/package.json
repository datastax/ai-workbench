{
	"name": "ai-workbench-site",
	"private": true,
	"license": "MIT",
	"version": "0.0.0",
	"type": "module",
	"description": "AI Workbench landing page + docs site (VitePress). Markdown source lives in /docs at the repo root; this app stages a copy and renders it.",
	"scripts": {
		"stage-docs": "node scripts/stage-docs.mjs",
		"predev": "npm run stage-docs",
		"prebuild": "npm run stage-docs",
		"dev": "vitepress dev .docs-staged",
		"build": "vitepress build .docs-staged",
		"preview": "vitepress preview .docs-staged"
	},
	"devDependencies": {
		"vitepress": "^1.6.0",
		"vue": "^3.5.0"
	},
	"overrides": {
		"vite": "6.4.2"
	}
}
