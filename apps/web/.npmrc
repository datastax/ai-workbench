; openapi-typescript@7 declares a peer dep on typescript@^5.x but the
; project (apps/web + runtime) is on typescript@^6 — the runtime APIs
; openapi-typescript uses are stable across TS 5/6, so the peer
; constraint is too tight rather than a real incompatibility. Pin
; `legacy-peer-deps` here so `npm ci` resolves cleanly in CI without
; everyone needing to remember --legacy-peer-deps on the command line.
;
; Drop this file once openapi-typescript ships a version that
; advertises typescript@>=5 (currently tracked in the upstream
; project; see https://github.com/openapi-ts/openapi-typescript).
legacy-peer-deps=true
