{
  "name": "ai-workbench",
  "version": "0.0.0",
  "description": "Single-runtime, multi-workspace workbench for Astra DB and the Data API",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/root.js",
  "scripts": {
    "dev": "tsx watch src/root.ts",
    "start": "node dist/root.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "hono": "^4.7.0",
    "pino": "^9.6.0",
    "ulid": "^2.3.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
